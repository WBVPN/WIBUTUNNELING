#!/bin/bash
# ==========================================
# WIBU TUNNELING - algojo-wibu (v5.0 — awk optimization)
# ==========================================
source /etc/wibutunnel/bot.conf 2>/dev/null
DB_IP="/etc/wibutunnel/limit_ip.db"
DB_LOCK="/etc/wibutunnel/locked_users.db"
LOCK_CONF="/etc/wibutunnel/lock.conf"

LOCK_DURATION=15
if [ -f "$LOCK_CONF" ]; then source "$LOCK_CONF"; fi
[[ ! -f "$DB_IP" ]] && exit 0

# [MATA ELANG V2 - NEW LOGIC] Deteksi real IP via Log 3 Menit (Support Cloudflare/CDN)
LOG_FILE="/var/log/xray/access.log"
OFFSET_FILE="/etc/wibutunnel/tmp/algojo_offset"
LAST_OFFSET=$(cat "$OFFSET_FILE" 2>/dev/null || echo 0)
NEW_OFFSET=$(stat -c%s "$LOG_FILE" 2>/dev/null || echo 0)
if [[ $NEW_OFFSET -lt $LAST_OFFSET ]]; then LAST_OFFSET=0; fi

THRESH=$(date -d '3 minutes ago' +'%Y/%m/%d %H:%M:%S')
LOGIN_DATA=$(dd if="$LOG_FILE" bs=1 skip=$LAST_OFFSET count=$((NEW_OFFSET-LAST_OFFSET)) 2>/dev/null | awk -v thresh="$THRESH" '$1" "$2 >= thresh && /accepted/ { for(i=1;i<=NF;i++){ if($i=="accepted"){ ip=$(i-1); sub(/^(tcp|udp):/, "", ip); sub(/:[0-9]+$/, "", ip); break } }; email=$NF; gsub(/[^a-zA-Z0-9_-]/, "", email); if(email != "dummy" && email != "api" && ip != "127.0.0.1" && ip != "") { if (!seen[email, ip]++) { ips[email] = (ips[email] ? ips[email]" " : "") ip; } } } END { for (e in ips) print e, ips[e] }' 2>/dev/null)
echo "$NEW_OFFSET" > "$OFFSET_FILE"

USERS_TO_LOCK=()
while read -r email ip_list; do
    if [[ -z "$email" || -z "$ip_list" ]]; then continue; fi
    max_ip=$(grep "^${email}:" "$DB_IP" 2>/dev/null | cut -d: -f2)
    [[ "$max_ip" == "0" || -z "$max_ip" ]] && continue

    ip_count=$(echo "$ip_list" | wc -w)
    if [[ $ip_count -gt $max_ip ]]; then
        if ! grep -q "^${email}:" "$DB_LOCK" 2>/dev/null; then
            proto="UNKNOWN"
            grep -q "^${email}:" /etc/xray/vless_exp.conf 2>/dev/null && proto="VLESS"
            grep -q "^${email}:" /etc/xray/vmess_exp.conf 2>/dev/null && proto="VMESS"
            grep -q "^${email}:" /etc/xray/trojan_exp.conf 2>/dev/null && proto="TROJAN"
            
            # Lock database
            now=$(date +%s)
            unlock_time=$((now + (LOCK_DURATION * 60)))
            echo "${email}:${now}:${unlock_time}:IP_LIMIT" >> "$DB_LOCK"
            
            USERS_TO_LOCK+=("$email")
            
            # Async Telegram Notification
            (
                DOMAIN=$(cat /etc/xray/domain 2>/dev/null || echo "Unknown")
                WAKTU=$(date '+%d %b %Y %H:%M WIB')
                PESAN="🔒 <b>USER DIKUNCI OTOMATIS</b>\n\n<b>User     :</b> <code>${email}</code>\n<b>Alasan   :</b> Melebihi Limit IP\n<b>Durasi   :</b> ${LOCK_DURATION} menit\n<b>Waktu    :</b> ${WAKTU}\n<b>Domain   :</b> <code>${DOMAIN}</code>\n\n<i>Account akan otomatis dibuka setelah durasi habis.</i>"
                curl -s --max-time 10 -X POST "https://api.telegram.org/bot${BOT_TOKEN}/sendMessage" -F "chat_id=${CHAT_ID}" -F "disable_web_page_preview=true" -F "parse_mode=html" -F "text=${PESAN}" >/dev/null 2>&1
            ) &
        fi
    fi
done <<< "$LOGIN_DATA"

if [[ ${#USERS_TO_LOCK[@]} -gt 0 ]]; then
    # BATCH LOCK IN XRAY (1 JQ CALL)
    jq_args=()
    for usr in "${USERS_TO_LOCK[@]}"; do
        jq_args+=("$usr")
    done
    TMP_CFG=$(mktemp /tmp/xray.XXXXXX.json)
    trap 'rm -f "$TMP_CFG"' EXIT
    jq --argjson users "$(printf '%s\n' "${jq_args[@]}" | jq -R . | jq -s .)" '(.routing.rules[] | select(.outboundTag == "blocked" and .user != null) | .user) |= (. + $users | unique)' /usr/local/etc/xray/config.json > "$TMP_CFG"
    if jq empty "$TMP_CFG" >/dev/null 2>&1; then
        mv "$TMP_CFG" /usr/local/etc/xray/config.json
        systemctl restart xray >/dev/null 2>&1
    else
        rm -f "$TMP_CFG"
    fi
fi
